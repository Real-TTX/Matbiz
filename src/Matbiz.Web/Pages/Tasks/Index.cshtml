@page
@model Matbiz.Web.Pages.Tasks.IndexModel
@using TaskStatus = Matbiz.Web.Modules.Tasks.Models.TaskStatus
@{ ViewData["Title"] = "Aufgaben"; }

<div class="d-flex align-items-center mb-3">
    <h1 class="me-auto mb-0">Aufgaben</h1>
    <a class="btn btn-primary" href="/Tasks/Edit">
        <i class="bi bi-plus-lg"></i> Neue Aufgabe
    </a>
</div>

<div class="alert-row mb-3">
    <a class="alert-tile alert-tile-overdue @(Model.Status == "overdue" ? "active" : "")"
       href="?status=overdue&scope=@Model.Scope">
        <i class="bi bi-exclamation-triangle"></i>
        <strong>@Model.OverdueCount</strong> überfällig
    </a>
    <a class="alert-tile alert-tile-today @(Model.Status == "today" ? "active" : "")"
       href="?status=today&scope=@Model.Scope">
        <i class="bi bi-calendar-day"></i>
        <strong>@Model.TodayCount</strong> heute fällig
    </a>
    <a class="alert-tile alert-tile-open @(Model.Status == "open" ? "active" : "")"
       href="?status=open&scope=@Model.Scope">
        <i class="bi bi-list-task"></i>
        <strong>@Model.OpenCount</strong> offen gesamt
    </a>
</div>

<form class="filter-bar mb-3"
      hx-get="/Tasks"
      hx-trigger="input changed delay:200ms from:input[name=Q], change from:select"
      hx-target="#task-table"
      hx-swap="outerHTML"
      hx-push-url="true">

    <div class="position-relative" style="max-width: 260px; flex: 1 1 260px;">
        <i class="bi bi-search position-absolute" style="left: 0.75rem; top: 0.6rem; color: var(--text-muted);"></i>
        <input class="form-control ps-5" placeholder="Aufgaben suchen…" name="Q" value="@Model.Q" autocomplete="off" />
    </div>

    <select class="form-select" name="Scope" style="max-width: 180px;">
        <option value="all" selected="@(Model.Scope == "all")">Alle (ich + Team)</option>
        <option value="mine" selected="@(Model.Scope == "mine")">Nur meine</option>
        <option value="team" selected="@(Model.Scope == "team")">Nur Team</option>
    </select>

    <select class="form-select" name="Status" style="max-width: 180px;">
        <option value="open" selected="@(Model.Status == "open")">Status: Offen</option>
        <option value="overdue" selected="@(Model.Status == "overdue")">Status: Überfällig</option>
        <option value="today" selected="@(Model.Status == "today")">Status: Heute</option>
        <option value="week" selected="@(Model.Status == "week")">Status: Diese Woche</option>
        <option value="done" selected="@(Model.Status == "done")">Status: Erledigt</option>
        <option value="all" selected="@(Model.Status == "all")">Status: Alle</option>
    </select>

    <select class="form-select" name="Priority" style="max-width: 180px;">
        <option value="">Priorität: Alle</option>
        <option value="Urgent" selected="@(Model.Priority == TaskPriority.Urgent)">Dringend</option>
        <option value="High" selected="@(Model.Priority == TaskPriority.High)">Hoch</option>
        <option value="Normal" selected="@(Model.Priority == TaskPriority.Normal)">Normal</option>
        <option value="Low" selected="@(Model.Priority == TaskPriority.Low)">Niedrig</option>
    </select>
</form>

@await Html.PartialAsync("_TaskTable", Model)
