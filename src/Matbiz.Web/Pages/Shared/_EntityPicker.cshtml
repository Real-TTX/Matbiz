@model EntityPickerVm
@*
    Generic picker:
      - Display: icon + read-only label + search button + clear button
      - Hidden input named via Model.InputName for form binding
      - <dialog> with htmx-driven search hitting Model.SearchUrl
*@

<input type="hidden" id="@(Model.InputName.Replace('.', '-'))-id" name="@Model.InputName" value="@Model.SelectedId" />

<div class="entity-picker-display">
    <i class="bi @Model.IconClass text-muted"></i>
    <span id="@(Model.InputName.Replace('.', '-'))-label" class="flex-grow-1">
        @(string.IsNullOrEmpty(Model.SelectedLabel) ? Model.EmptyText : Model.SelectedLabel)
    </span>
    <button type="button" class="btn btn-sm btn-outline-secondary"
            onclick="entityPicker.open('@Model.DialogId', '@Model.InputName')"
            title="Suchen / Ändern">
        <i class="bi bi-search"></i>
    </button>
    <button type="button" class="btn btn-sm btn-outline-secondary"
            onclick="entityPicker.clear('@Model.InputName', '@Model.EmptyText')"
            title="Verknüpfung entfernen">
        <i class="bi bi-x"></i>
    </button>
</div>

<dialog id="@Model.DialogId" class="customer-picker-dialog"
        onclick="if (event.target === this) this.close()">
    <div class="picker-header">
        <h5 class="mb-0"><i class="bi @Model.IconClass me-2"></i>@Model.DialogTitle</h5>
        <button type="button" class="btn-close" onclick="this.closest('dialog').close()"></button>
    </div>
    <div class="picker-search position-relative">
        <i class="bi bi-search position-absolute" style="left: 0.85rem; top: 0.7rem; color: var(--text-muted);"></i>
        <input id="@(Model.DialogId)-search" class="form-control ps-5" placeholder="@Model.PlaceholderText"
               name="q" autocomplete="off"
               hx-get="@Model.SearchUrl"
               hx-trigger="input changed delay:200ms, load"
               hx-target="#@(Model.DialogId)-results"
               hx-swap="innerHTML" />
    </div>
    <div id="@(Model.DialogId)-results" class="picker-results"></div>
    <div class="picker-footer">
        <button type="button" class="btn btn-secondary" onclick="this.closest('dialog').close()">Abbrechen</button>
    </div>
</dialog>
