@model string
@*
    Mini-Vorschau eines PDF-Templates als Inline-SVG.
    Variants: Classic / Modern / Minimal
*@

@if (Model == "Modern")
{
    <svg viewBox="0 0 100 142" xmlns="http://www.w3.org/2000/svg" class="pdf-preview-svg">
        <rect x="0" y="0" width="100" height="142" fill="#fff" stroke="#dee2e6" stroke-width="0.5" />
        <rect x="0" y="0" width="100" height="14" fill="var(--brand-primary, #1b6ec2)" />
        <rect x="6" y="4" width="20" height="6" rx="1" fill="rgba(255,255,255,0.85)" />
        <rect x="60" y="4" width="34" height="2" fill="rgba(255,255,255,0.7)" />
        <rect x="60" y="7" width="30" height="1.5" fill="rgba(255,255,255,0.5)" />
        <rect x="60" y="10" width="32" height="1.5" fill="rgba(255,255,255,0.5)" />
        <rect x="6" y="22" width="40" height="3" fill="#212529" />
        <rect x="6" y="27" width="35" height="1.5" fill="#6c757d" />
        <rect x="6" y="30" width="38" height="1.5" fill="#6c757d" />
        <rect x="60" y="22" width="34" height="2" fill="#212529" />
        <rect x="60" y="26" width="34" height="1.5" fill="#6c757d" />
        <rect x="6" y="44" width="50" height="5" fill="var(--brand-primary, #1b6ec2)" />
        <rect x="6" y="51" width="88" height="0.8" fill="var(--brand-primary, #1b6ec2)" />
        <rect x="6" y="60" width="88" height="4" fill="#e9ecef" />
        @for (int i = 0; i < 4; i++)
        {
            <rect x="6" y="@(66 + i * 6)" width="88" height="0.5" fill="#dee2e6" />
        }
        <rect x="70" y="100" width="24" height="2" fill="#6c757d" />
        <rect x="70" y="104" width="24" height="3" fill="#212529" />
        <rect x="6" y="132" width="88" height="0.5" fill="#dee2e6" />
        <rect x="6" y="135" width="30" height="1" fill="#adb5bd" />
        <rect x="40" y="135" width="20" height="1" fill="#adb5bd" />
        <rect x="65" y="135" width="29" height="1" fill="#adb5bd" />
    </svg>
}
else if (Model == "Minimal")
{
    <svg viewBox="0 0 100 142" xmlns="http://www.w3.org/2000/svg" class="pdf-preview-svg">
        <rect x="0" y="0" width="100" height="142" fill="#fff" stroke="#dee2e6" stroke-width="0.5" />
        <rect x="70" y="6" width="24" height="2" fill="#212529" />
        <rect x="6" y="11" width="88" height="0.4" fill="#adb5bd" />
        <rect x="6" y="22" width="40" height="2" fill="#212529" />
        <rect x="6" y="26" width="35" height="1.5" fill="#6c757d" />
        <rect x="6" y="29" width="38" height="1.5" fill="#6c757d" />
        <rect x="60" y="22" width="34" height="2" fill="#212529" />
        <rect x="60" y="26" width="34" height="1.5" fill="#6c757d" />
        <rect x="6" y="44" width="50" height="5" fill="#212529" />
        <rect x="6" y="60" width="88" height="3" fill="#f8f9fa" />
        @for (int i = 0; i < 5; i++)
        {
            <rect x="6" y="@(65 + i * 5)" width="88" height="0.4" fill="#dee2e6" />
        }
        <rect x="70" y="100" width="24" height="2" fill="#6c757d" />
        <rect x="70" y="104" width="24" height="3" fill="#212529" />
        <rect x="6" y="132" width="88" height="0.4" fill="#dee2e6" />
        <rect x="6" y="135" width="30" height="1" fill="#adb5bd" />
        <rect x="40" y="135" width="20" height="1" fill="#adb5bd" />
        <rect x="65" y="135" width="29" height="1" fill="#adb5bd" />
    </svg>
}
else
{
    @* Classic — Default *@
    <svg viewBox="0 0 100 142" xmlns="http://www.w3.org/2000/svg" class="pdf-preview-svg">
        <rect x="0" y="0" width="100" height="142" fill="#fff" stroke="#dee2e6" stroke-width="0.5" />
        <rect x="6" y="6" width="20" height="8" rx="1" fill="#dee2e6" />
        <rect x="60" y="6" width="34" height="2" fill="#212529" />
        <rect x="60" y="9" width="30" height="1.5" fill="#6c757d" />
        <rect x="60" y="12" width="32" height="1.5" fill="#6c757d" />
        <rect x="6" y="24" width="40" height="2" fill="#212529" />
        <rect x="6" y="28" width="35" height="1.5" fill="#6c757d" />
        <rect x="6" y="31" width="38" height="1.5" fill="#6c757d" />
        <rect x="60" y="24" width="34" height="2" fill="#212529" />
        <rect x="60" y="28" width="34" height="1.5" fill="#6c757d" />
        <rect x="6" y="46" width="40" height="4" fill="#212529" />
        <rect x="6" y="60" width="88" height="3.5" fill="#e9ecef" />
        @for (int i = 0; i < 5; i++)
        {
            <rect x="6" y="@(65 + i * 5)" width="88" height="0.5" fill="#dee2e6" />
        }
        <rect x="70" y="100" width="24" height="2" fill="#6c757d" />
        <rect x="70" y="104" width="24" height="3" fill="#212529" />
        <rect x="6" y="132" width="88" height="0.5" fill="#dee2e6" />
        <rect x="6" y="135" width="30" height="1" fill="#adb5bd" />
        <rect x="40" y="135" width="20" height="1" fill="#adb5bd" />
        <rect x="65" y="135" width="29" height="1" fill="#adb5bd" />
    </svg>
}
