@model List<Matbiz.Web.Modules.Customers.Models.Customer>

<div class="col-md-6">
    <div class="panel">
        <div class="panel-header">
            <h5 class="mb-0"><i class="bi bi-person-plus me-2"></i>Neue Kontakte</h5>
            <span class="text-muted small">@Model.Count Eintrag/Einträge</span>
        </div>
        @if (Model.Count == 0)
        {
            <p class="text-muted m-3">Noch keine Kontakte angelegt.</p>
        }
        else
        {
            <ul class="dash-list">
                @foreach (var c in Model)
                {
                    var company = c.Company?.Name ?? c.CompanyName;
                    <li class="dash-row">
                        <a class="dash-row-body" href="/Customers/@c.Id">
                            <div>
                                <strong>@c.Name</strong>
                                @if (!string.IsNullOrEmpty(company))
                                {
                                    <span class="text-muted">— @company</span>
                                }
                            </div>
                            <div class="small text-muted d-flex flex-wrap gap-2 mt-1">
                                <span><i class="bi bi-calendar3"></i> @c.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                                @if (!string.IsNullOrEmpty(c.LocationLine))
                                {
                                    <span><i class="bi bi-geo-alt"></i> @c.LocationLine</span>
                                }
                            </div>
                        </a>
                    </li>
                }
                <li class="dash-row dash-row-more">
                    <a class="dash-show-all" href="/Customers">Alle anzeigen <i class="bi bi-arrow-right"></i></a>
                </li>
            </ul>
        }
    </div>
</div>
