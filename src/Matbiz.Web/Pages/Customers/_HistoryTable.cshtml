@model Matbiz.Web.Pages.Customers.DetailModel
@{
    string SortLink(string column)
    {
        var nextSort = Model.HistorySort switch
        {
            "at_desc" when column == "at" => "at_asc",
            "at_asc" when column == "at" => "at_desc",
            "action_asc" when column == "action" => "action_desc",
            "action_desc" when column == "action" => "action_asc",
            _ => column == "at" ? "at_desc" : "action_asc"
        };
        return $"/Customers/{Model.Id}?tab=historie&q={Uri.EscapeDataString(Model.HistorySearch ?? "")}&historySort={nextSort}";
    }

    string SortIcon(string column)
    {
        var s = Model.HistorySort;
        if (column == "at")
            return s == "at_asc" ? "bi-arrow-up" : s == "at_desc" ? "bi-arrow-down" : "bi-arrow-down-up text-muted";
        if (column == "action")
            return s == "action_asc" ? "bi-arrow-up" : s == "action_desc" ? "bi-arrow-down" : "bi-arrow-down-up text-muted";
        return "bi-arrow-down-up text-muted";
    }
}

<div id="history-table">
    @{ var rows = Model.FilteredHistory.ToList(); }

    @if (rows.Count == 0)
    {
        <div class="empty-state">
            <i class="bi bi-clock-history"></i>
            <p class="mt-2 mb-0 text-muted">
                @(string.IsNullOrEmpty(Model.HistorySearch) ? "Noch keine Einträge." : $"Keine Treffer für „{Model.HistorySearch}\".")
            </p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle history-table">
                <thead>
                    <tr>
                        <th style="width: 160px;">
                            <a class="th-sort" href="@SortLink("at")">Datum / Zeit <i class="bi @SortIcon("at")"></i></a>
                        </th>
                        <th style="width: 130px;">
                            <a class="th-sort" href="@SortLink("action")">Aktion <i class="bi @SortIcon("action")"></i></a>
                        </th>
                        <th>Details</th>
                        <th style="width: 170px;">Bearbeiter</th>
                        <th style="width: 80px;" class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in rows)
                    {
                        <tr data-history-id="@h.Id">
                            <td class="text-nowrap">
                                <i class="bi bi-calendar3 text-muted me-1"></i>
                                <strong>@h.At.ToLocalTime().ToString("dd.MM.yyyy")</strong>
                                <span class="text-muted ms-1">@h.At.ToLocalTime().ToString("HH:mm")</span>
                            </td>
                            <td>
                                @{ var (iconCls, badgeCls) = ActionStyle(h.Action); }
                                <span class="history-action @badgeCls"><i class="bi @iconCls"></i> @h.Action</span>
                            </td>
                            <td>
                                <div data-history-display>@h.Details</div>
                                <form method="post" asp-page-handler="EditHistory" data-history-edit class="d-none mt-1">
                                    <input type="hidden" name="entryId" value="@h.Id" />
                                    <textarea name="details" class="form-control form-control-sm" rows="3">@h.Details</textarea>
                                    <div class="d-flex gap-1 mt-1">
                                        <button class="btn btn-primary btn-sm"><i class="bi bi-check2"></i> Speichern</button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleHistoryEdit(this, false)">Abbrechen</button>
                                    </div>
                                </form>
                                @if (Model.HistoryAttachments.TryGetValue(h.Id, out var atts) && atts.Count > 0)
                                {
                                    <div class="d-flex flex-wrap gap-1 mt-1">
                                        @foreach (var a in atts)
                                        {
                                            <a href="/files/@a.Id" target="_blank" class="history-attachment" title="@(a.SizeBytes / 1024) KB">
                                                <i class="bi bi-paperclip"></i> @a.FileName
                                            </a>
                                        }
                                    </div>
                                }
                                @if (h.EditedAt is DateTime ed)
                                {
                                    <small class="text-muted d-block mt-1"><i class="bi bi-pencil"></i> Bearbeitet @ed.ToLocalTime().ToString("dd.MM.yyyy HH:mm")@(string.IsNullOrEmpty(h.EditedByUserId) ? "" : $" von {Model.ActorName(h.EditedByUserId)}")</small>
                                }
                                @if (!string.IsNullOrEmpty(h.OnBehalfOfAdminId))
                                {
                                    <small class="text-warning d-block"><i class="bi bi-shield-lock"></i> via Remote-Zugriff durch @(Model.ActorName(h.OnBehalfOfAdminId))</small>
                                }
                            </td>
                            <td>
                                <i class="bi bi-person-circle text-muted me-1"></i>@Model.ActorName(h.ActorUserId)
                            </td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-link text-muted py-0" onclick="toggleHistoryEdit(this, true)" title="Bearbeiten">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="DeleteHistory" class="d-inline"
                                      onsubmit="return confirm('Eintrag wirklich löschen?');">
                                    <input type="hidden" name="entryId" value="@h.Id" />
                                    <button class="btn btn-sm btn-link text-muted py-0" title="Löschen"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="small text-muted">@rows.Count Eintrag/Einträge</div>
    }
</div>

@functions {
    static (string icon, string css) ActionStyle(string action) => action switch
    {
        "Created" => ("bi-plus-circle", "act-created"),
        "Updated" => ("bi-pencil", "act-updated"),
        "Note" => ("bi-chat-dots", "act-note"),
        _ => ("bi-arrow-right-circle", "act-default")
    };
}

<script>
    // Inline-Toggle für Historie-Bearbeiten — zeigt Textarea, hidet die Anzeige.
    // Wird auch von Company-History verwendet.
    window.toggleHistoryEdit = window.toggleHistoryEdit || function (btn, edit) {
        var row = btn.closest('tr');
        if (!row) return;
        var display = row.querySelector('[data-history-display]');
        var form = row.querySelector('[data-history-edit]');
        if (!display || !form) return;
        display.classList.toggle('d-none', edit);
        form.classList.toggle('d-none', !edit);
        if (edit) form.querySelector('textarea')?.focus();
    };
</script>
