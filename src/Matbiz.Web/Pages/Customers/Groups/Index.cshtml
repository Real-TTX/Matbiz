@page
@model Matbiz.Web.Pages.Customers.Groups.IndexModel
@{ ViewData["Title"] = "Gruppen"; }

<div class="d-flex align-items-center mb-3">
    <h1 class="me-auto mb-0">Gruppen</h1>
    <partial name="_ColumnConfigDropdown" model="@(new ColumnConfigVm(Model.Columns))" />
    <a class="btn btn-primary ms-2" href="/Customers/Groups/Create">
        <i class="bi bi-plus-lg"></i> Neue Gruppe
    </a>
</div>

<div class="list-toolbar">
    <input class="form-control form-control-sm list-toolbar-search" data-filter-search="group-list-body" placeholder="Suchen…" />
    <select class="form-select form-select-sm" onchange="window.location.href='?entity='+this.value">
        <option value="all" selected="@(Model.Entity == "all")">Alle (@Model.CountAll)</option>
        <option value="contacts" selected="@(Model.Entity == "contacts")">Kontakte (@Model.CountContacts)</option>
        <option value="companies" selected="@(Model.Entity == "companies")">Firmen (@Model.CountCompanies)</option>
    </select>
    <div class="list-toolbar-spacer"></div>
    <span class="text-muted small"><span data-filter-count="group-list-body">@Model.Items.Count</span> Eintrag/Einträge</span>
</div>

@{
    var visibleColCount = Model.Columns.All.Count(c => Model.Columns.Is(c.Key)) + 1;
}
<table class="table table-hover align-middle">
    <thead>
        <tr>
            @foreach (var col in Model.Columns.All.Where(c => Model.Columns.Is(c.Key)))
            {
                <th>@col.Label</th>
            }
            <th class="text-end">Aktionen</th>
        </tr>
    </thead>
    <tbody id="group-list-body" data-paginate data-page-size="25">
        @if (Model.Items.Count == 0)
        {
            <tr class="empty-row"><td colspan="@visibleColCount">Keine Daten</td></tr>
        }
        else
        {
            @foreach (var g in Model.Items)
            {
                var isDyn = g.Kind == CustomerGroupKind.Dynamic;
                var isCompany = g.EntityKind == CustomerGroupEntityKind.Company;
                var memberCount = isCompany ? g.CompanyMembers.Count : g.Members.Count;
                <tr data-filter-text="@g.Name @g.Description">
                    @foreach (var col in Model.Columns.All.Where(x => Model.Columns.Is(x.Key)))
                    {
                        <td>
                            @switch (col.Key)
                            {
                                case "name":
                                    <a class="text-decoration-none text-reset" href="/Customers/Groups/Detail/@g.Id">
                                        <i class="bi @(isDyn ? "bi-funnel-fill text-info" : "bi-collection-fill text-muted") me-1"></i>
                                        <strong>@g.Name</strong>
                                    </a>
                                    break;
                                case "entity":
                                    @if (isCompany)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-building"></i> Firmen</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-person-vcard"></i> Kontakte</span>
                                    }
                                    break;
                                case "kind":
                                    <span class="badge @(isDyn ? "bg-info-subtle text-info" : "bg-secondary-subtle text-secondary")">
                                        @(isDyn ? "Dynamisch" : "Statisch")
                                    </span>
                                    break;
                                case "description":
                                    <span class="text-muted">@g.Description</span>
                                    break;
                                case "members":
                                    @if (!isDyn)
                                    {
                                        <span class="text-muted"><i class="bi bi-person"></i> @memberCount</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">(berechnet)</span>
                                    }
                                    break;
                                case "updated":
                                    <span class="text-muted small">@g.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy")</span>
                                    break;
                            }
                        </td>
                    }
                    <td class="text-end">
                        <a class="btn btn-outline-secondary btn-sm" title="Öffnen" href="/Customers/Groups/Detail/@g.Id">
                            <i class="bi bi-folder2-open"></i>
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<div data-pagination="group-list-body"></div>
