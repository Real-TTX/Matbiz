@page "/Admin/TaxRates/Edit/{Id:guid?}"
@model Matbiz.Web.Pages.Admin.TaxRates.EditModel
@{ ViewData["Title"] = Model.IsNew ? "Neuer Steuersatz" : "Steuersatz bearbeiten"; }

<h1>@(Model.IsNew ? "Neuer Steuersatz" : "Steuersatz bearbeiten")</h1>

<form method="post" class="row g-3" style="max-width: 700px;">
    <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

    <div class="col-md-6">
        <label class="form-label">Name *</label>
        <input class="form-control" asp-for="Input.Name" required />
        <div class="form-text">z.B. „Voll 19 %", „Ermäßigt 7 %".</div>
    </div>
    <div class="col-md-3">
        <label class="form-label">Prozent *</label>
        <input type="number" step="0.001" min="0" max="100" class="form-control" asp-for="Input.Percent" required />
    </div>
    <div class="col-md-3">
        <label class="form-label">Sortierung</label>
        <input type="number" class="form-control" asp-for="Input.SortOrder" />
    </div>
    <div class="col-12">
        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" asp-for="Input.IsDefault" id="def" />
            <label class="form-check-label" for="def">Als Default bei neuen Artikeln</label>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Speichern</button>
        <a class="btn btn-secondary" href="/Admin/TaxRates"><i class="bi bi-x-lg"></i> Abbrechen</a>
    </div>
</form>
