@page
@model Matbiz.Web.Pages.Admin.TaxRates.IndexModel
@{ ViewData["Title"] = "Steuersätze"; }

<div class="d-flex align-items-center mb-3">
    <h1 class="me-auto mb-0">Steuersätze</h1>
    <a class="btn btn-primary" href="/Admin/TaxRates/Edit"><i class="bi bi-plus-lg"></i> Neuer Steuersatz</a>
</div>

@if (TempData["StatusError"] is string err)
{
    <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle"></i> @err</div>
}

<div class="list-toolbar">
    <input class="form-control form-control-sm list-toolbar-search" data-filter-search="taxrate-list-body" placeholder="Suchen…" />
    <div class="list-toolbar-spacer"></div>
    <span class="text-muted small"><span data-filter-count="taxrate-list-body">@Model.Items.Count</span> Eintrag/Einträge</span>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th class="text-end" style="width: 120px;">Prozent</th>
            <th style="width: 100px;">Default</th>
            <th style="width: 100px;">Sortierung</th>
            <th style="width: 80px;" class="text-end">Aktionen</th>
        </tr>
    </thead>
    <tbody id="taxrate-list-body" data-paginate data-page-size="25">
        @if (Model.Items.Count == 0)
        {
            <tr class="empty-row"><td colspan="5">Keine Daten</td></tr>
        }
        else
        {
            @foreach (var t in Model.Items)
            {
                <tr data-filter-text="@t.Name">
                    <td><a class="text-decoration-none text-reset" href="/Admin/TaxRates/Edit/@t.Id"><strong>@t.Name</strong></a></td>
                    <td class="text-end">@t.Percent.ToString("0.###") %</td>
                    <td>
                        @if (t.IsDefault)
                        {
                            <span class="badge bg-info-subtle text-info"><i class="bi bi-star-fill"></i> Default</span>
                        }
                    </td>
                    <td>@t.SortOrder</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="/Admin/TaxRates/Edit/@t.Id"><i class="bi bi-pencil"></i></a>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@t.Id" class="d-inline"
                              onsubmit="return confirm('Steuersatz „@t.Name\" löschen?');">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<div data-pagination="taxrate-list-body"></div>
