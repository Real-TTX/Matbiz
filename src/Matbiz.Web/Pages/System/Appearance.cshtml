@page
@model Matbiz.Web.Pages.System.AppearanceModel
@using Matbiz.Web.Modules.SystemSettings
@using Matbiz.Web.Modules.SystemSettings.Models
@{ ViewData["Title"] = "System"; Layout = "_AdminLayout"; }

<h1>System</h1>
<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link @(Model.Tab == "aussehen" ? "active" : "")" href="?tab=aussehen"><i class="bi bi-palette"></i> Aussehen</a></li>
    <li class="nav-item"><a class="nav-link @(Model.Tab == "firma" ? "active" : "")" href="?tab=firma"><i class="bi bi-building"></i> Firma</a></li>
    <li class="nav-item"><a class="nav-link @(Model.Tab == "pdf" ? "active" : "")" href="?tab=pdf"><i class="bi bi-file-earmark-pdf"></i> PDF</a></li>
</ul>

@if (TempData["StatusMessage"] is string msg)
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> @msg</div>
}
@if (TempData["StatusError"] is string err)
{
    <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle"></i> @err</div>
}

@if (Model.Tab == "aussehen")
{
    <form method="post" asp-page-handler="Save" class="row g-4" style="max-width: 1000px;">
        <div class="col-md-6">
            <h3 class="mb-3"><i class="bi bi-type me-2"></i>Identität</h3>
            <div class="mb-3">
                <label class="form-label">Anwendungsname</label>
                <input class="form-control" asp-for="AppName" />
            </div>

            <div class="mb-3">
                <label class="form-label d-flex justify-content-between">
                    <span>Logo-Höhe in Sidebar</span>
                    <span class="text-muted small"><span id="logo-h-val">@Model.LogoHeightPx</span> px</span>
                </label>
                <input type="range" class="form-range" min="24" max="96" step="2" asp-for="LogoHeightPx"
                       oninput="document.getElementById('logo-h-val').textContent=this.value;document.getElementById('logo-h-preview').style.height=this.value+'px';" />
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" role="switch" asp-for="ShowAppNameUnderLogo" id="showAppName" />
                <label class="form-check-label" for="showAppName">Anwendungsname unter dem Logo anzeigen</label>
                <div class="form-text">Aus = nur Logo (sinnvoll wenn der Name schon Teil des Logos ist).</div>
            </div>


            @if (Model.Current.LogoBytes is { Length: > 0 })
            {
                <div class="border rounded p-2 mb-3" style="background: var(--bg-subtle);">
                    <div class="text-muted small mb-1">Vorschau Sidebar:</div>
                    <img id="logo-h-preview" src="/branding/logo?v=@Model.Current.Version"
                         style="height: @(Model.LogoHeightPx)px; display: block;" alt="Logo" />
                </div>
            }
            <div class="alert alert-info small mt-4">
                <i class="bi bi-info-circle"></i> <strong>Dunkles oder helles Theme</strong> ist eine persönliche Einstellung —
                jeder Benutzer wählt sie unter <a href="/Account/Manage">Mein Konto</a>.
            </div>
        </div>

        <div class="col-md-6">
            <h3 class="mb-3"><i class="bi bi-droplet me-2"></i>Farben</h3>

            <label class="form-label">Primärfarbe</label>
            <div class="color-row">
                <input type="color" asp-for="PrimaryColor" oninput="document.getElementById('p-prev').style.background=this.value;document.getElementById('p-prev').style.color=onColor(this.value);this.nextElementSibling.value=this.value" />
                <input type="text" class="form-control form-control-sm" asp-for="PrimaryColor" />
                <span id="p-prev" class="color-preview" style="background: @Model.PrimaryColor; color: @ContrastHelper.OnColor(Model.PrimaryColor);">
                    <i class="bi bi-check2"></i> Primär-Button
                </span>
            </div>

            <label class="form-label">Akzentfarbe 1</label>
            <div class="color-row">
                <input type="color" asp-for="AccentColor1" oninput="document.getElementById('a1-prev').style.background=this.value;document.getElementById('a1-prev').style.color=onColor(this.value);this.nextElementSibling.value=this.value" />
                <input type="text" class="form-control form-control-sm" asp-for="AccentColor1" />
                <span id="a1-prev" class="color-preview" style="background: @Model.AccentColor1; color: @ContrastHelper.OnColor(Model.AccentColor1);">
                    <i class="bi bi-star"></i> Akzent 1
                </span>
            </div>

            <label class="form-label">Akzentfarbe 2</label>
            <div class="color-row">
                <input type="color" asp-for="AccentColor2" oninput="document.getElementById('a2-prev').style.background=this.value;document.getElementById('a2-prev').style.color=onColor(this.value);this.nextElementSibling.value=this.value" />
                <input type="text" class="form-control form-control-sm" asp-for="AccentColor2" />
                <span id="a2-prev" class="color-preview" style="background: @Model.AccentColor2; color: @ContrastHelper.OnColor(Model.AccentColor2);">
                    <i class="bi bi-tag"></i> Akzent 2
                </span>
            </div>
        </div>

        <div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Speichern</button>
        </div>
    </form>

    <hr class="my-4" style="max-width: 1000px;" />

    <div style="max-width: 1000px;">
        <h3 class="mb-3"><i class="bi bi-image me-2"></i>Logos</h3>
        <p class="text-muted small">
            Zwei separate Logo-Slots — jedes wird im jeweiligen Theme angezeigt.
            Wenn nur ein Light-Logo gesetzt ist, wird es auch im Dark Mode genutzt (Fallback).
        </p>

        <div class="row g-4">

            <!-- Light Mode -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-light text-dark d-flex align-items-center">
                        <i class="bi bi-sun me-2"></i><strong>Light Mode</strong>
                    </div>
                    <div class="card-body">
                        <div class="logo-preview-checker mb-3" style="background-color: #fff;">
                            @if (Model.Current.LogoBytes is { Length: > 0 })
                            {
                                <img src="/branding/logo?v=@Model.Current.Version" alt="Light Logo" style="max-height: 80px;" />
                            }
                            else
                            {
                                <span class="text-muted small">Kein Logo</span>
                            }
                        </div>
                        @if (Model.Current.LogoBytes is { Length: > 0 })
                        {
                            <div class="form-text small mb-2">
                                <code>@(Model.Current.LogoContentType ?? "?")</code> ·
                                @((Model.Current.LogoBytes.Length / 1024.0).ToString("N1")) KB
                            </div>
                        }
                        <form method="post" asp-page-handler="UploadLogo" enctype="multipart/form-data" class="d-flex gap-2 flex-wrap">
                            <input asp-for="Logo" type="file" class="form-control form-control-sm flex-grow-1"
                                   accept="image/png,image/jpeg,image/svg+xml,image/webp" />
                            <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-upload"></i></button>
                            @if (Model.Current.LogoBytes is { Length: > 0 })
                            {
                                <button type="submit" formaction="?handler=ClearLogo" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Light-Logo entfernen?');"><i class="bi bi-trash"></i></button>
                            }
                        </form>
                        <div class="form-text small mt-2">PNG, JPG, SVG, WebP — max. 2 MB. Wird wie-hochgeladen angezeigt.</div>
                    </div>
                </div>
            </div>

            <!-- Dark Mode -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-dark text-white d-flex align-items-center">
                        <i class="bi bi-moon-stars me-2"></i><strong>Dark Mode</strong>
                    </div>
                    <div class="card-body">
                        <div class="logo-preview-checker mb-3" style="background-color: #222;">
                            @if (Model.Current.LogoDarkBytes is { Length: > 0 })
                            {
                                <img src="/branding/logo/dark?v=@Model.Current.Version" alt="Dark Logo" style="max-height: 80px;" />
                            }
                            else
                            {
                                <span class="text-muted small">Kein Logo — Fallback auf Light-Logo</span>
                            }
                        </div>
                        @if (Model.Current.LogoDarkBytes is { Length: > 0 })
                        {
                            <div class="form-text small mb-2">
                                <code>@(Model.Current.LogoDarkContentType ?? "?")</code> ·
                                @((Model.Current.LogoDarkBytes.Length / 1024.0).ToString("N1")) KB
                            </div>
                        }
                        <form method="post" asp-page-handler="UploadDarkLogo" enctype="multipart/form-data" class="d-flex gap-2 flex-wrap">
                            <input asp-for="LogoDark" type="file" class="form-control form-control-sm flex-grow-1"
                                   accept="image/png,image/jpeg,image/svg+xml,image/webp" />
                            <button class="btn btn-sm btn-primary" type="submit"><i class="bi bi-upload"></i></button>
                            @if (Model.Current.LogoDarkBytes is { Length: > 0 })
                            {
                                <button type="submit" formaction="?handler=ClearDarkLogo" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Dark-Logo entfernen?');"><i class="bi bi-trash"></i></button>
                            }
                        </form>
                        <div class="form-text small mt-2">Helle Variante für dunkles Theme — wird wie-hochgeladen angezeigt.</div>
                    </div>
                </div>
            </div>

        </div>
    </div>
}
else if (Model.Tab == "firma")
{
    <form method="post" asp-page-handler="SaveCompany" class="row g-3" style="max-width: 1000px;">
        <h3 class="mt-2"><i class="bi bi-building me-2"></i>Firma / Adresse</h3>

        <div class="col-md-12">
            <label class="form-label">Vollständiger Firmenname (für Rechnungen)</label>
            <input class="form-control" asp-for="Company.CompanyLegalName" placeholder="z.B. Mustermann GmbH" />
        </div>
        <div class="col-md-8">
            <label class="form-label">Straße + Hausnummer</label>
            <input class="form-control" asp-for="Company.CompanyStreet" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Geschäftsführer / Inhaber</label>
            <input class="form-control" asp-for="Company.ManagingDirector" />
        </div>
        <div class="col-md-3">
            <label class="form-label">PLZ</label>
            <input class="form-control" asp-for="Company.CompanyPostalCode" />
        </div>
        <div class="col-md-5">
            <label class="form-label">Ort</label>
            <input class="form-control" asp-for="Company.CompanyCity" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Land</label>
            <input class="form-control" asp-for="Company.CompanyCountry" placeholder="Deutschland" />
        </div>

        <h3 class="mt-4"><i class="bi bi-telephone me-2"></i>Kontakt</h3>
        <div class="col-md-4">
            <label class="form-label">E-Mail</label>
            <input class="form-control" type="email" asp-for="Company.CompanyEmail" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Telefon</label>
            <input class="form-control" asp-for="Company.CompanyPhone" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Website</label>
            <input class="form-control" asp-for="Company.CompanyWebsite" placeholder="https://…" />
        </div>

        <h3 class="mt-4"><i class="bi bi-bank me-2"></i>Steuer- &amp; Bankdaten</h3>
        <div class="col-md-6">
            <label class="form-label">Umsatzsteuer-ID (USt-ID)</label>
            <input class="form-control" asp-for="Company.VatId" placeholder="DE123456789" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Steuernummer (Finanzamt)</label>
            <input class="form-control" asp-for="Company.TaxNumber" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Registergericht</label>
            <input class="form-control" asp-for="Company.RegistrationCourt" placeholder="Amtsgericht München" />
            <div class="form-text">Pflichtangabe für GmbH/UG/AG (§ 35a GmbHG).</div>
        </div>
        <div class="col-md-6">
            <label class="form-label">Handelsregister-Nummer</label>
            <input class="form-control" asp-for="Company.RegistrationNumber" placeholder="HRB 12345" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Bank</label>
            <input class="form-control" asp-for="Company.BankName" />
        </div>
        <div class="col-md-4">
            <label class="form-label">IBAN</label>
            <input class="form-control" asp-for="Company.Iban" />
        </div>
        <div class="col-md-2">
            <label class="form-label">BIC</label>
            <input class="form-control" asp-for="Company.Bic" />
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Speichern</button>
        </div>
    </form>
}
else if (Model.Tab == "pdf")
{
    <form method="post" asp-page-handler="SavePdf" class="row g-3" style="max-width: 900px;">
        <h3 class="mt-2"><i class="bi bi-file-earmark-pdf me-2"></i>PDF-Einstellungen</h3>
        <p class="text-muted small">Diese Texte erscheinen auf jedem ausgehenden Beleg (Rechnung, Angebot, …).</p>

        <h4 class="mt-3 mb-2">Layout</h4>
        <div class="col-12">
            <div class="row g-3">
                @{
                    var templates = new[]
                    {
                        ("Classic", "Klassisch", "Logo oben links, Firma oben rechts, schlichter schwarz-weiß Stil."),
                        ("Modern",  "Modern",    "Farbiger Balken oben in Primärfarbe, Akzent unter dem Titel."),
                        ("Minimal", "Minimal",   "Kein Logo-Balken, nur dünne Trennlinie. Reine Typografie.")
                    };
                }
                @foreach (var (key, name, desc) in templates)
                {
                    var isActive = (Model.Company.PdfTemplate ?? "Classic") == key;
                    <div class="col-md-4">
                        <label class="pdf-template-card @(isActive ? "active" : "")">
                            <input type="radio" name="Company.PdfTemplate" value="@key" @(isActive ? "checked" : "") class="d-none" />
                            <div class="pdf-template-preview">
                                <partial name="_PdfTemplatePreview" model="@key" />
                            </div>
                            <div class="pdf-template-info">
                                <strong>@name</strong>
                                <div class="small text-muted">@desc</div>
                            </div>
                        </label>
                    </div>
                }
            </div>
        </div>

        <h4 class="mt-4 mb-2">Kontorahmen (DATEV-Export)</h4>
        <div class="col-md-6">
            <label class="form-label">Kontorahmen</label>
            <select class="form-select" asp-for="Company.ChartOfAccounts">
                <option value="SKR03">SKR03 — Standard (KMU, Handel, Dienstleister)</option>
                <option value="SKR04">SKR04 — Bilanzgliederung (Kapitalgesellschaften)</option>
            </select>
            <div class="form-text">Wirkt auf die Erlöskonten im DATEV-CSV-Export.</div>
        </div>

        <h4 class="mt-4 mb-2">Texte</h4>

        <input type="hidden" asp-for="Company.CompanyLegalName" />
        <input type="hidden" asp-for="Company.CompanyStreet" />
        <input type="hidden" asp-for="Company.CompanyPostalCode" />
        <input type="hidden" asp-for="Company.CompanyCity" />
        <input type="hidden" asp-for="Company.CompanyCountry" />
        <input type="hidden" asp-for="Company.CompanyEmail" />
        <input type="hidden" asp-for="Company.CompanyPhone" />
        <input type="hidden" asp-for="Company.CompanyWebsite" />
        <input type="hidden" asp-for="Company.VatId" />
        <input type="hidden" asp-for="Company.TaxNumber" />
        <input type="hidden" asp-for="Company.ManagingDirector" />
        <input type="hidden" asp-for="Company.RegistrationCourt" />
        <input type="hidden" asp-for="Company.RegistrationNumber" />
        <input type="hidden" asp-for="Company.BankName" />
        <input type="hidden" asp-for="Company.Iban" />
        <input type="hidden" asp-for="Company.Bic" />

<script>
    // Aktive Klasse auf Klick — Bootstrap-Karten-Look ohne JS-Framework
    document.querySelectorAll('.pdf-template-card input[type=radio]').forEach(function (r) {
        r.addEventListener('change', function () {
            document.querySelectorAll('.pdf-template-card').forEach(function (c) { c.classList.remove('active'); });
            r.closest('.pdf-template-card').classList.add('active');
        });
    });
</script>

        <div class="col-12">
            <label class="form-label">Standard-Zahlungsbedingung</label>
            <input class="form-control" asp-for="Company.DefaultPaymentTerms"
                   placeholder="Zahlbar innerhalb 14 Tagen netto ohne Abzug." />
            <div class="form-text">Wird beim Erstellen einer Rechnung vorbelegt — kann pro Beleg überschrieben werden.</div>
        </div>
        <div class="col-12">
            <label class="form-label">Fußzeile auf jedem PDF</label>
            <textarea class="form-control" asp-for="Company.PdfFooterText" rows="4"
                      placeholder="Frei wählbar — z.B. AGB-Hinweis, Handelsregister, weitere rechtliche Pflichtangaben."></textarea>
            <div class="form-text">Erscheint zusätzlich zu den Firmen-/Bankdaten im Fuß des PDF.</div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Speichern</button>
        </div>
    </form>
}

<script>
    function onColor(hex) {
        if (!hex || hex[0] !== '#' || hex.length < 7) return '#fff';
        const r = parseInt(hex.substr(1, 2), 16);
        const g = parseInt(hex.substr(3, 2), 16);
        const b = parseInt(hex.substr(5, 2), 16);
        const lin = (c) => { c /= 255; return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4); };
        const lum = 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
        return lum > 0.55 ? '#1f2328' : '#ffffff';
    }
</script>
