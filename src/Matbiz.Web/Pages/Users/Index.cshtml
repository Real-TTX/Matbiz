@page
@model Matbiz.Web.Pages.Users.IndexModel
@{ ViewData["Title"] = "Benutzer"; Layout = "_AdminLayout"; }

<div class="d-flex align-items-center mb-3">
    <h1 class="me-auto mb-0">Benutzerverwaltung</h1>
    <a class="btn btn-primary" href="/Users/Edit"><i class="bi bi-person-plus"></i> Neuer Benutzer</a>
</div>

<div class="list-toolbar">
    <input class="form-control form-control-sm list-toolbar-search" data-filter-search="user-list-body" placeholder="Suche Name oder E-Mail…" />
    <select class="form-select form-select-sm" data-filter-attr="role" data-filter-target="user-list-body">
        <option value="">Alle Rollen</option>
        <option value="Admin">Admin</option>
        <option value="User">User</option>
    </select>
    <select class="form-select form-select-sm" data-filter-attr="status" data-filter-target="user-list-body">
        <option value="">Alle Status</option>
        <option value="active">Nur aktive</option>
        <option value="inactive">Nur inaktive</option>
    </select>
    <div class="list-toolbar-spacer"></div>
    <span class="text-muted small"><span data-filter-count="user-list-body">@Model.Items.Count</span> Eintrag/Einträge</span>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>E-Mail</th>
            <th>Rolle</th>
            <th>Status</th>
            <th class="text-end">Aktionen</th>
        </tr>
    </thead>
    <tbody id="user-list-body" data-paginate data-page-size="25">
        @if (Model.Items.Count == 0)
        {
            <tr class="empty-row"><td colspan="5">Keine Daten</td></tr>
        }
        else
        {
            @foreach (var u in Model.Items)
            {
                var isSelf = u.Id == Model.CurrentUserId;
                var role = Model.PrimaryRole(u.Id);
                <tr class="@(u.IsActive ? "" : "text-muted")"
                    data-filter-text="@(u.DisplayName ?? "") @u.Email"
                    data-filter-role="@role"
                    data-filter-status="@(u.IsActive ? "active" : "inactive")">
                    <td>
                        <a class="text-decoration-none text-reset" href="/Users/Edit/@u.Id">
                            <strong>@(u.DisplayName ?? u.Email)</strong>
                        </a>
                        @if (isSelf)
                        {
                            <span class="badge bg-info-subtle text-info ms-2">Du</span>
                        }
                    </td>
                    <td><i class="bi bi-envelope text-muted me-1"></i>@u.Email</td>
                    <td>
                        @if (role == "Admin")
                        {
                            <span class="badge bg-warning-subtle text-warning"><i class="bi bi-shield-fill"></i> Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-person"></i> User</span>
                        }
                    </td>
                    <td>
                        @if (u.IsActive)
                        {
                            <span class="badge bg-success-subtle text-success"><i class="bi bi-check-circle"></i> Aktiv</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary-subtle text-secondary"><i class="bi bi-pause-circle"></i> Inaktiv</span>
                        }
                    </td>
                    <td class="text-end">
                        @if (!isSelf && u.IsActive)
                        {
                            <form method="post" action="/impersonation/start" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="targetUserId" value="@u.Id" />
                                <input type="hidden" name="returnUrl" value="/" />
                                <button class="btn btn-sm btn-warning" title="Als diesen Benutzer arbeiten">
                                    <i class="bi bi-shield-lock"></i> Remote-Zugriff
                                </button>
                            </form>
                        }
                        <a class="btn btn-sm btn-outline-secondary" href="/Users/Edit/@u.Id" title="Bearbeiten">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<div data-pagination="user-list-body"></div>
