@page
@model ManageModel
@using Matbiz.Web.Modules.SystemSettings.Models
@{ ViewData["Title"] = "Mein Konto"; }

<h1>Mein Konto</h1>

@if (TempData["StatusMessage"] is string msg)
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> @msg</div>
}

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == "profile" ? "active" : "")" href="/Account/Manage">
            <i class="bi bi-person"></i> Profil
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.ActiveTab == "appearance" ? "active" : "")" href="/Account/Manage?tab=appearance">
            <i class="bi bi-palette"></i> Aussehen
        </a>
    </li>
</ul>

@if (Model.ActiveTab == "profile")
{
    <div style="max-width: 600px;">
        <form method="post" asp-page-handler="Profile" class="mb-4">
            <h3 class="mb-3"><i class="bi bi-person me-2"></i>Profil</h3>
            <div class="mb-3">
                <label class="form-label">E-Mail</label>
                <input class="form-control" value="@Model.CurrentUser?.Email" disabled />
            </div>
            <div class="mb-3">
                <label class="form-label">Anzeigename</label>
                <input class="form-control" asp-for="DisplayName" />
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Profil speichern</button>
        </form>

        <hr />

        <form method="post" asp-page-handler="ChangePassword">
            <h3 class="mb-3 mt-4"><i class="bi bi-key me-2"></i>Passwort ändern</h3>
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="mb-3">
                <label class="form-label">Aktuelles Passwort</label>
                <input type="password" class="form-control" asp-for="Password.Old" />
                <span asp-validation-for="Password.Old" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Neues Passwort</label>
                <input type="password" class="form-control" asp-for="Password.New" />
                <span asp-validation-for="Password.New" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Neues Passwort wiederholen</label>
                <input type="password" class="form-control" asp-for="Password.Confirm" />
                <span asp-validation-for="Password.Confirm" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Passwort speichern</button>
        </form>
    </div>
}
else
{
    <form method="post" asp-page-handler="Appearance" style="max-width: 700px;">
        <h3 class="mb-3"><i class="bi bi-circle-half me-2"></i>Theme</h3>
        <p class="text-muted">Persönliche Anzeigeeinstellung — gilt nur für dich.</p>
        <div class="row g-2">
            @foreach (var (val, label, cls, icon, desc) in new[]
            {
                (ThemeMode.Light,  "Hell",   "mp-light",  "bi-sun",     "Immer helle Oberfläche."),
                (ThemeMode.Dark,   "Dunkel", "mp-dark",   "bi-moon",    "Immer dunkle Oberfläche."),
                (ThemeMode.System, "System", "mp-system", "bi-display", "Folgt dem Betriebssystem.")
            })
            {
                <div class="col-md-4">
                    <label class="theme-card @(Model.Theme == val ? "active" : "")">
                        <input type="radio" class="d-none" asp-for="Theme" value="@val" />
                        <div class="mini-preview @cls">
                            <div class="mp-side"></div>
                            <div class="mp-main">
                                <div class="mp-bar"></div>
                                <div class="mp-bar" style="width: 70%;"></div>
                                <div class="mp-btn"></div>
                            </div>
                        </div>
                        <div class="text-center"><i class="bi @icon me-1"></i><strong>@label</strong></div>
                        <div class="small text-muted text-center">@desc</div>
                    </label>
                </div>
            }
        </div>
        <button type="submit" class="btn btn-primary mt-4"><i class="bi bi-check2"></i> Theme speichern</button>
    </form>
}
