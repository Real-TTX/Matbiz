@page
@model Matbiz.Web.Pages.Teams.IndexModel
@{ ViewData["Title"] = "Teams"; Layout = "_AdminLayout"; }

<div class="d-flex align-items-center mb-3">
    <h1 class="me-auto mb-0">Teams</h1>
    <button type="button" class="btn btn-primary"
            onclick="document.getElementById('create-form').classList.toggle('d-none')">
        <i class="bi bi-plus-lg"></i> Neues Team
    </button>
</div>

<form id="create-form" method="post" asp-page-handler="Create" class="border rounded p-3 mb-4 bg-light @(Model.ShowCreate ? "" : "d-none")">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Name *</label>
            <input class="form-control" asp-for="Draft.Name" required />
        </div>
        <div class="col-md-8">
            <label class="form-label">Beschreibung</label>
            <input class="form-control" asp-for="Draft.Description" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-3"><i class="bi bi-check2"></i> Anlegen</button>
</form>

<div class="list-toolbar">
    <input class="form-control form-control-sm list-toolbar-search" data-filter-search="team-list-body" placeholder="Suche Name, Abteilung, Beschreibung…" />
    <div class="list-toolbar-spacer"></div>
    <span class="text-muted small"><span data-filter-count="team-list-body">@Model.Items.Count</span> Eintrag/Einträge</span>
</div>

<table class="table table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Abteilung</th>
            <th>Beschreibung</th>
            <th>Mitglieder</th>
            <th class="text-end">Aktionen</th>
        </tr>
    </thead>
    <tbody id="team-list-body" data-paginate data-page-size="25">
        @if (Model.Items.Count == 0)
        {
            <tr class="empty-row"><td colspan="5">Keine Daten</td></tr>
        }
        else
        {
            @foreach (var t in Model.Items)
            {
                <tr data-filter-text="@t.Name @(t.Department?.Name) @t.Description">
                    <td><a class="text-decoration-none text-reset" href="/Teams/Detail/@t.Id"><strong>@t.Name</strong></a></td>
                    <td>
                        @if (t.Department is not null)
                        {
                            <a class="text-decoration-none text-reset" href="/Departments/Detail/@t.Department.Id">
                                <i class="bi bi-diagram-3 text-muted me-1"></i>@t.Department.Name
                            </a>
                        }
                    </td>
                    <td class="text-muted">@t.Description</td>
                    <td><i class="bi bi-person text-muted me-1"></i>@t.Members.Count</td>
                    <td class="text-end">
                        <a class="btn btn-outline-secondary btn-sm" title="Öffnen" href="/Teams/Detail/@t.Id"><i class="bi bi-folder2-open"></i></a>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
<div data-pagination="team-list-body"></div>
