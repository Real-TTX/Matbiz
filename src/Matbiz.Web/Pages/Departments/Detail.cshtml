@page "/Departments/Detail/{Id:guid}"
@model Matbiz.Web.Pages.Departments.DetailModel
@{
    ViewData["Title"] = Model.Dept?.Name ?? "Abteilung";
    var d = Model.Dept!;
}

@if (TempData["StatusMessage"] is string msg)
{
    <div class="alert alert-success py-2"><i class="bi bi-check-circle"></i> @msg</div>
}

<div class="d-flex align-items-start mb-3">
    <div class="dept-icon-lg"><i class="bi bi-diagram-3-fill"></i></div>
    <div class="ms-3 flex-grow-1">
        <h1 class="mb-0">@d.Name</h1>
    </div>
    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Abteilung wirklich löschen? Zugeordnete Teams werden nicht gelöscht, sondern nur entkoppelt.');">
        <button class="btn btn-outline-danger"><i class="bi bi-trash"></i> Abteilung löschen</button>
    </form>
</div>

<form method="post" asp-page-handler="Save" class="row g-3 mb-4" style="max-width: 700px;">
    <div class="col-12">
        <label class="form-label">Name *</label>
        <input class="form-control" asp-for="Name" required />
    </div>
    <div class="col-12">
        <label class="form-label">Beschreibung</label>
        <input class="form-control" asp-for="Description" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> Speichern</button>
    </div>
</form>

<h3 class="mt-5"><i class="bi bi-people-fill me-2"></i>Teams in dieser Abteilung</h3>

@if (d.Teams.Count == 0)
{
    <p class="text-muted">Noch keine Teams zugeordnet. Auf <a href="/Teams">Teams</a> kannst du beim Bearbeiten eines Teams diese Abteilung wählen.</p>
}
else
{
    <ul class="list-group" style="max-width: 600px;">
        @foreach (var t in d.Teams)
        {
            <li class="list-group-item d-flex align-items-center">
                <i class="bi bi-people-fill me-2 text-muted"></i>
                <a class="text-decoration-none text-reset" href="/Teams/Detail/@t.Id">@t.Name</a>
                @if (!string.IsNullOrEmpty(t.Description))
                {
                    <span class="text-muted small ms-2">— @t.Description</span>
                }
            </li>
        }
    </ul>
}
