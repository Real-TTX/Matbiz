# Copy to .env and adjust. docker-compose reads .env automatically.

# Externer Port unter dem die Web-App erreichbar ist
MATBIZ_PORT=8040

# Postgres
POSTGRES_DB=matbiz
POSTGRES_USER=matbiz
POSTGRES_PASSWORD=matbiz

# Initial-Admin (wird beim ersten Start angelegt)
MATBIZ_ADMIN_EMAIL=admin@matbiz.local
MATBIZ_ADMIN_PASSWORD=ChangeMe!2026

ASPNETCORE_ENVIRONMENT=Production

# Beim ersten Start Demo-Kunden/Tasks/Mitarbeiter anlegen (lokale Testumgebung)
MATBIZ_SEED_SAMPLE_DATA=true
